FROM php:8.3-apache

RUN docker-php-ext-install pdo pdo_mysql

RUN a2enmod rewrite

COPY backend/ /var/www/html/
COPY backend/apache/000-default.conf /etc/apache2/sites-available/000-default.conf
COPY backend/docker/entrypoint-production.sh /usr/local/bin/entrypoint-production.sh

RUN chown -R www-data:www-data /var/www/html \
 && chmod +x /usr/local/bin/entrypoint-production.sh \
 && echo "ServerName localhost" >> /etc/apache2/apache2.conf

WORKDIR /var/www/html

EXPOSE 80

ENTRYPOINT ["/usr/local/bin/entrypoint-production.sh"]